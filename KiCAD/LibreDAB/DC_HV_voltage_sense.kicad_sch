				(thickness 0.5)
				(bold yes)
			)
			(justify left bottom)
		)
		(uuid "3849cc25-de3b-46fd-bf0a-44d80e837d93")
	)
	(text "fc ​≈ 1/(2π*RC*Cf)​\nR1 = 10 kΩ, Cf = 470 pF → fc ≈ 34 kHz"
